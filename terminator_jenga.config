[global_config]
  dbus = False
[keybindings]
[profiles]
  [[default]]
    scrollback_infinite = True
[layouts]
  [[default]]
    [[[window0]]]
      type = Window
      parent = ""
    [[[child1]]]
      type = Terminal
      parent = window0
  [[jenga]]
    [[[window0]]]
      type = Window
      parent = ""
      size = 1600, 1000
    [[[columns]]]
      type = HPaned
      parent = window0
      ratio = 0.333
    [[[left]]]
      type = VPaned
      parent = columns
      order = 0
      ratio = 0.333
    [[[left_bottom]]]
      type = VPaned
      parent = left
      order = 1
      ratio = 0.5
    [[[middle_right]]]
      type = HPaned
      parent = columns
      order = 1
      ratio = 0.5
    [[[middle]]]
      type = VPaned
      parent = middle_right
      order = 0
      ratio = 0.333
    [[[middle_bottom]]]
      type = VPaned
      parent = middle
      order = 1
      ratio = 0.5
    [[[right]]]
      type = VPaned
      parent = middle_right
      order = 1
      ratio = 0.333
    [[[right_bottom]]]
      type = VPaned
      parent = right
      order = 1
      ratio = 0.5
    [[[terminal1]]]
      type = Terminal
      parent = left
      order = 0
      title = [1] RealSense
      command = '''bash -lc 'echo "RealSense 카메라 구동 중..."; source /opt/ros/humble/setup.bash && ros2 launch realsense2_camera rs_align_depth_launch.py depth_module.depth_profile:=848x480x30 rgb_camera.color_profile:=1280x720x30 initial_reset:=true align_depth.enable:=true enable_rgbd:=true pointcloud.enable:=true; exec bash''''
    [[[terminal2]]]
      type = Terminal
      parent = left_bottom
      order = 0
      title = [2] Robot Driver
      command = '''bash -lc 'echo "로봇 드라이버 기동 중..."; cd "$HOME/ws_cobot2_pjt" && source install/setup.bash && ros2 launch m0609_rg2_bringup bringup_camera.launch.py mode:=real host:=192.168.1.100; exec bash''''
    [[[terminal3]]]
      type = Terminal
      parent = left_bottom
      order = 1
      title = [3] MoveIt
      command = '''bash -lc 'echo "MoveIt 대기 중 (5초)..."; sleep 5; cd "$HOME/ws_cobot2_pjt" && source install/setup.bash && ros2 launch m0609_rg2_moveit movegroup_only.launch.py; exec bash''''
    [[[terminal4]]]
      type = Terminal
      parent = middle
      order = 0
      title = [4] YOLO Jenga
      command = '''bash -lc 'echo "YOLO 젠가 검출 노드 구동 중..."; cd "$HOME/ws_cobot2_pjt" && source install/setup.bash && ros2 run object_detection jenga_detection; exec bash''''
    [[[terminal5]]]
      type = Terminal
      parent = middle_bottom
      order = 0
      title = [5] YOLO Hand
      command = '''bash -lc 'echo "YOLO 손 검출 노드 구동 중..."; cd "$HOME/ws_cobot2_pjt" && source install/setup.bash && ros2 run object_hand object_hand; exec bash''''
    [[[terminal6]]]
      type = Terminal
      parent = middle_bottom
      order = 1
      title = [6] Hand Obstacle
      command = '''bash -lc 'echo "손 회피 장애물 퍼블리셔 구동 중..."; cd "$HOME/ws_cobot2_pjt" && source install/setup.bash && ros2 run object_hand hand_obstacle_publisher; exec bash''''
    [[[terminal7]]]
      type = Terminal
      parent = right
      order = 0
      title = [7] Inspector
      command = '''bash -lc 'echo "젠가 검사 메인 제어 노드 구동 중..."; cd "$HOME/ws_cobot2_pjt" && source install/setup.bash && ros2 run robot_control jenga_inspector; exec bash''''
    [[[terminal8]]]
      type = Terminal
      parent = right_bottom
      order = 0
      title = [8] FastAPI Backend
      command = '''bash -lc 'echo "웹 백엔드 및 ROS-HMI 브릿지 구동 중..."; cd "$HOME/ws_cobot2_pjt" && source install/setup.bash && cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000; exec bash''''
    [[[terminal9]]]
      type = Terminal
      parent = right_bottom
      order = 1
      title = [9] Vite Frontend
      command = '''bash -lc 'echo "웹 프론트엔드 구동 중..."; cd "$HOME/ws_cobot2_pjt/frontend" && npm run dev -- --host 0.0.0.0 --port 5173; exec bash''''
[plugins]
